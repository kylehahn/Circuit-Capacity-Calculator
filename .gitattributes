# Auto-detect text vs binary; normalize to LF in repo
* text=auto eol=lf

# Force CRLF for Windows-only scripts
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Force LF for Unix scripts
*.sh    text eol=lf

# Binary blobs
*.png   binary
*.jpg   binary
*.jpeg  binary
*.ico   binary
*.glb   binary
*.gltf  binary
*.pdf   binary
*.pptx  binary
*.xlsx  binary
*.docx  binary
