root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.{cmake,CMakeLists.txt}]
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2

[*.{ps1,bat,cmd}]
end_of_line = crlf
